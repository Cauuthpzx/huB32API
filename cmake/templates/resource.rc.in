#include <windows.h>

VS_VERSION_INFO VERSIONINFO
 FILEVERSION @RC_VERSION_MAJOR@,@RC_VERSION_MINOR@,@RC_VERSION_PATCH@,0
 PRODUCTVERSION @RC_VERSION_MAJOR@,@RC_VERSION_MINOR@,@RC_VERSION_PATCH@,0
 FILEFLAGSMASK 0x3fL
 FILEFLAGS 0x0L
 FILEOS 0x40004L
 FILETYPE 0x1L
 FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName",      "Hub32 Solutions"
            VALUE "FileDescription",  "@RC_DESCRIPTION@"
            VALUE "FileVersion",      "@RC_VERSION_STRING@"
            VALUE "InternalName",     "@RC_FILENAME@"
            VALUE "LegalCopyright",   "GPL-2.0"
            VALUE "OriginalFilename", "@RC_FILENAME@"
            VALUE "ProductName",      "hub32api"
            VALUE "ProductVersion",   "@RC_VERSION_STRING@"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END
